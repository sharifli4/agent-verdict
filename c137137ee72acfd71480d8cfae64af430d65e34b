n segments:\n            draw.text((x, y), text, fill=color, font=font)\n            bbox = font.getbbox(text)\n            x += bbox[2] - bbox[0]\n        y += LINE_HEIGHT\n\n    return img\n\n\ndef make_typing_frames(cmd: str, prefix: str = \"$ \") -> list[tuple[list[str], int]]:\n    \"\"\"Generate progressive typing frames for a command.\"\"\"\n    frames = []\n    for i in range(1, len(cmd) + 1):\n        frames.append(([prefix + cmd[:i] + \"█\"], 50))\n    # pause after full command before executing\n    frames.append(([prefix + cmd], 400))\n    return frames\n\n\ndef build_output_frames(lines: list[str]) -> list[tuple[list[str], int]]:\n    \"\"\"Reveal output lines one by one.\"\"\"\n    frames = []\n    for i in range(1, len(lines) + 1):\n        duration = 120 if i < len(lines) else 2500\n        frames.append((lines[:i], duration))\n    return frames\n\n\ndef main():\n    demo_dir = Path(__file__).parent\n    project_dir = demo_dir.parent\n    out_path = project_dir / \"demo\" / \"demo.gif\"\n\n    # Collect outputs\n    out1 = run_script(str(demo_dir / \"demo_decorator.py\"))\n    out2 = run_script(str(demo_dir / \"demo_dropped.py\"))\n    out3 = run_script(str(demo_dir / \"demo_pipeline.py\"))\n\n    all_frames: list[Image.Image] = []\n    all_durations: list[int] = []\n\n    # --- Scene 1: decorator demo ---\n    scenes = [\n        (\"@verdict decorator — good result\", \"python demo/demo_decorator.py\", out1),\n        (\"@verdict decorator — dropped result\", \"python demo/demo_dropped.py\", out2),\n        (\"VerdictPipeline — direct usage\", \"python demo/demo_pipeline.py\", out3),\n    ]\n\n    for title, cmd, output in scenes:\n        output_lines = [l for l in output.strip().split(\"\\n\")]\n\n        # typing the command\n        for lines, dur in make_typing_frames(cmd):\n            img = render_frame(lines, title)\n            all_frames.append(img)\n            all_durations.append(dur)\n\n        # showing output progressively\n        c